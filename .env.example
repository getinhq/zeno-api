# Required for /projects and schema: password must use %40 for @
# Docker (same compose network): postgresql://zeno_admin:zeno@postgres:5432/zeno_db
# Docker (container network): use service hostname `postgres`
DATABASE_URL=postgresql://chimera_admin:ZenoChimera%4025@postgres:5432/zeno_chimera_db
# Local (Mac host):
# DATABASE_URL=postgresql://chimera_admin:ZenoChimera%4025@localhost:5432/zeno_chimera_db
# Local (Mac host):
# MONGO_URI=mongodb://localhost:27017/zeno_chimera_db
MONGO_URI=mongodb://mongodb:27017/zeno_chimera_db

# If URI has no database path, set: ZENO_MONGO_DB=zeno_db

# Redis (workflow locks / presence)
REDIS_URL=redis://localhost:6379/0
# Docker: REDIS_URL=redis://redis:6379/0

# CAS: auto = MinIO/S3 if S3_* set, else filesystem (ZENO_CAS_ROOT)
CAS_STORAGE_BACKEND=auto
# NAS-only local dev:
ZENO_CAS_ROOT=/tmp/zeno_cas
# Docker compose without MinIO profile: ZENO_CAS_ROOT=/app/cas_data

# MinIO / S3 (use with zeno-infra: docker compose --profile full up -d)
# S3_ENDPOINT_URL=http://minio:9000
# S3_ACCESS_KEY=minioadmin
# S3_SECRET_KEY=minioadmin
# S3_BUCKET_CAS=zeno-cas
